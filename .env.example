# Required environment variables for inference.py
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=your_huggingface_token_here

# SPACE_URL is optional — inference.py auto-detects the server at startup:
#   1. http://localhost:8000  (local dev server: uv run server)
#   2. http://localhost:7860  (local Docker: docker run -p 7860:7860 ...)
#   3. SPACE_URL env var      (set below to force a specific HF Space)
#   4. https://10doshi12-firewatch-env.hf.space  (hardcoded fallback)
# Uncomment and set only if you need to force a specific HF Space:
# SPACE_URL=https://your-space.hf.space

# Optional: for local Docker testing
LOCAL_IMAGE_NAME=firewatch-env-local
